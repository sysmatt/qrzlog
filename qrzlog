#!/usr/bin/env python3
"""Interact with the QRZ Logbook API — upload or download ADIF logs."""

import argparse
import configparser
from datetime import date, timedelta
import html
import logging
import logging.handlers
import os
import re
import sys
import urllib.error
import urllib.parse
import urllib.request

QRZ_API_URL   = "https://logbook.qrz.com/api"
DEFAULT_CONFIG = os.path.expanduser("~/.config/qrzlog/qrzlog.ini")

WSJT_X_LOG_CANDIDATES = [
    os.path.expanduser("~/.local/share/WSJT-X/wsjtx_log.adi"),
    os.path.expanduser("~/.local/share/WSJT-X/wsjtx_log.adif"),
]


# =============================================================================
# BEGIN APPLOG
# =============================================================================

class AppLogger:
    """
    Application logger with TRACE/VERBOSE/DEBUG/INFO levels and configurable destinations.

    Custom levels:
        TRACE   =  5   super-verbose full dumps
        VERBOSE = 15   informative detail beyond normal INFO

    Destinations: console stream (stderr by default), log file, syslog.
    Console output: plain message for INFO, [LEVEL] prefix for all other levels.
    File/syslog output: includes program name, timestamp, and level.

    Construction:
        log = AppLogger("myprog", level=AppLogger.VERBOSE)
        log = AppLogger.from_args(args, "myprog")
        log = AppLogger.from_args(args, "myprog", cfg=config)  # args > cfg > defaults

    Config file ([logging] section):
        [logging]
        level   = verbose    # trace | debug | verbose | info
        logfile = /path/to/myprog.log
        syslog  = false
    """

    TRACE   = 5
    VERBOSE = 15

    # Register custom levels at class-definition time
    logging.addLevelName(TRACE,   "TRACE")
    logging.addLevelName(VERBOSE, "VERBOSE")

    # Inject .trace() and .verbose() into logging.Logger
    def _trace_m(self, msg, *a, **kw):
        if self.isEnabledFor(5):  self._log(5,  msg, a, **kw)
    def _verbose_m(self, msg, *a, **kw):
        if self.isEnabledFor(15): self._log(15, msg, a, **kw)
    logging.Logger.trace   = _trace_m
    logging.Logger.verbose = _verbose_m
    del _trace_m, _verbose_m

    class _ConsoleFormatter(logging.Formatter):
        """Plain message for INFO; [LEVEL] prefix for everything else."""
        def __init__(self, plain_levels=None):
            super().__init__()
            self._plain = frozenset(plain_levels if plain_levels is not None else [logging.INFO])

        def format(self, record):
            msg = record.getMessage()
            if record.levelno not in self._plain:
                msg = f"[{record.levelname}] {msg}"
            if record.exc_info:
                if not record.exc_text:
                    record.exc_text = self.formatException(record.exc_info)
            if record.exc_text:
                msg = f"{msg}\n{record.exc_text}"
            return msg

    def __init__(
        self,
        name: str,
        level: int = logging.INFO,
        *,
        stream=sys.stderr,
        logfile: str | None = None,
        use_syslog: bool = False,
        plain_levels: list[int] | None = None,
    ):
        self._logger = logging.getLogger(name)
        self._logger.setLevel(level)
        self._logger.handlers.clear()
        self._logger.propagate = False

        if stream is not None:
            h = logging.StreamHandler(stream)
            h.setLevel(level)
            h.setFormatter(self._ConsoleFormatter(plain_levels=plain_levels))
            self._logger.addHandler(h)

        if logfile:
            h = logging.FileHandler(logfile, encoding="utf-8")
            h.setLevel(level)
            h.setFormatter(logging.Formatter(
                fmt=f"%(asctime)s {name} [%(levelname)s] %(message)s",
                datefmt="%Y-%m-%d %H:%M:%S",
            ))
            self._logger.addHandler(h)

        if use_syslog:
            address = "/dev/log" if os.path.exists("/dev/log") else ("localhost", 514)
            h = logging.handlers.SysLogHandler(address=address)
            h.setLevel(level)
            h.setFormatter(logging.Formatter(f"{name}: [%(levelname)s] %(message)s"))
            self._logger.addHandler(h)

    @classmethod
    def from_args(
        cls,
        args,
        program_name: str,
        cfg: configparser.ConfigParser | None = None,
        **kwargs,
    ) -> "AppLogger":
        """
        Build from an argparse Namespace, optionally merging a ConfigParser.
        Args take precedence over the [logging] config section.

        Namespace attrs read (all optional):
            trace, debug, verbose  log level — most verbose flag wins
            logfile                log file path
            syslog                 enable syslog

        ConfigParser [logging] keys (used when the corresponding arg is absent):
            level   = trace | debug | verbose | info
            logfile = /path/to/file
            syslog  = true | false
        """
        _lvl = {"trace": cls.TRACE, "debug": logging.DEBUG,
                "verbose": cls.VERBOSE, "info": logging.INFO}

        cfg_level   = _lvl.get((cfg.get("logging", "level", fallback="") if cfg else "").lower(), logging.INFO)
        cfg_logfile = cfg.get("logging", "logfile", fallback=None)        if cfg else None
        cfg_syslog  = cfg.getboolean("logging", "syslog", fallback=False) if cfg else False

        if   getattr(args, "trace",   False): level = cls.TRACE
        elif getattr(args, "debug",   False): level = logging.DEBUG
        elif getattr(args, "verbose", False): level = cls.VERBOSE
        else:                                 level = cfg_level

        logfile    = getattr(args, "logfile", None) or cfg_logfile
        use_syslog = getattr(args, "syslog", False) or cfg_syslog

        return cls(name=program_name, level=level, logfile=logfile, use_syslog=use_syslog, **kwargs)

    def trace(self,   msg, *a, **kw): self._logger.trace(msg,   *a, **kw)
    def verbose(self, msg, *a, **kw): self._logger.verbose(msg, *a, **kw)
    def debug(self,   msg, *a, **kw): self._logger.debug(msg,   *a, **kw)
    def info(self,    msg, *a, **kw): self._logger.info(msg,    *a, **kw)
    def warning(self, msg, *a, **kw): self._logger.warning(msg, *a, **kw)
    def error(self,   msg, *a, **kw): self._logger.error(msg,   *a, **kw)
    def critical(self,msg, *a, **kw): self._logger.critical(msg,*a, **kw)

# =============================================================================
# END APPLOG
# =============================================================================


def load_config(config_path: str) -> configparser.ConfigParser:
    cfg = configparser.ConfigParser()
    cfg.read(config_path)
    return cfg


def find_default_log_file(cfg: configparser.ConfigParser | None = None) -> str | None:
    """Return configured log_file from [qrzlog], or first existing WSJT-X candidate."""
    if cfg and cfg.has_option("qrzlog", "log_file"):
        return cfg.get("qrzlog", "log_file")
    for path in WSJT_X_LOG_CANDIDATES:
        if os.path.isfile(path):
            return path
    return None


def resolve_api_key(args, cfg: configparser.ConfigParser) -> str | None:
    """Precedence: --key flag > QRZ_API_KEY env var > config file."""
    if args.key:
        return args.key
    if os.environ.get("QRZ_API_KEY"):
        return os.environ["QRZ_API_KEY"]
    if cfg.has_option("qrzlog", "api_key"):
        return cfg.get("qrzlog", "api_key")
    return None


def qrz_post(params: dict, log: AppLogger) -> str:
    payload = urllib.parse.urlencode(params).encode("utf-8")
    req = urllib.request.Request(QRZ_API_URL, data=payload, method="POST")
    req.add_header("Content-Type", "application/x-www-form-urlencoded")
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return resp.read().decode("utf-8", errors="replace")
    except urllib.error.HTTPError as e:
        log.error("HTTP error %d: %s", e.code, e.reason)
        sys.exit(1)
    except urllib.error.URLError as e:
        log.error("Connection error: %s", e.reason)
        sys.exit(1)


def parse_response(body: str) -> dict:
    """Parse a QRZ API response.

    Responses are &-separated key=value pairs. ADIF, when present, is always
    the last field and is extracted by finding its marker in the raw body so
    that records on continuation lines are not lost.
    """
    result = {}
    body = body.strip()
    prefix = body

    # ADIF is always last — find it before any &/newline splitting.
    amp_adif = body.upper().find("&ADIF=")
    if amp_adif != -1:
        prefix = body[:amp_adif]
        result["ADIF"] = html.unescape(body[amp_adif + 6:])
    else:
        for i, line in enumerate(body.splitlines()):
            if line.upper().startswith("ADIF="):
                prefix = "\n".join(body.splitlines()[:i])
                result["ADIF"] = html.unescape("\n".join(body.splitlines()[i:])[5:])
                break

    for segment in prefix.replace("\n", "&").split("&"):
        segment = segment.strip()
        if "=" in segment:
            k, v = segment.split("=", 1)
            k = k.strip()
            if k and k.upper() != "ADIF":
                result[k] = urllib.parse.unquote(v.strip())

    return result


def check_result(result: dict, log: AppLogger) -> None:
    status = result.get("RESULT", "UNKNOWN")
    if status == "AUTH":
        log.error("Authentication failed — check your API key.")
        sys.exit(1)
    if status == "FAIL":
        log.error("Request failed: %s", result.get("REASON", "unknown reason"))
        sys.exit(1)


def _parse_adif_records(adif_data: str) -> tuple[str, list[str]]:
    """Split raw ADIF text into (header, [record, ...]).

    The header is everything up to and including <EOH> (empty string if absent).
    Each record string includes its trailing <EOR> tag, kept inline.
    """
    eoh_idx = adif_data.upper().find("<EOH>")
    if eoh_idx != -1:
        header = adif_data[:eoh_idx + 5]
        body   = adif_data[eoh_idx + 5:]
    else:
        header = ""
        body   = adif_data

    records = []
    for part in re.split(r"<EOR>", body, flags=re.IGNORECASE):
        r = part.strip()
        if r:
            records.append(r + " <EOR>")
    return header, records


def _adif_qso_date(record: str) -> str:
    """Return the QSO_DATE value (YYYYMMDD) from a record, or empty string."""
    m = re.search(r"<QSO_DATE:\d+>(\d{8})", record, re.IGNORECASE)
    return m.group(1) if m else ""


def _build_adif(header: str, record: str) -> str:
    """Build a complete single-record ADIF string."""
    return f"{header}\n{record}" if header else record


def do_upload(
    api_key: str,
    adif_file: str,
    dry_run: bool,
    log: AppLogger,
    tail: int | None = None,
    tail_days: int | None = None,
) -> None:
    try:
        with open(adif_file, "r", encoding="utf-8", errors="replace") as f:
            adif_data = f.read()
    except FileNotFoundError:
        log.error("File not found: %s", adif_file)
        sys.exit(1)

    if not adif_data.strip():
        log.error("ADIF file is empty.")
        sys.exit(1)

    header, records = _parse_adif_records(adif_data)
    eor_count = len(re.findall(r"<EOR>", adif_data, re.IGNORECASE))
    if eor_count == 0:
        log.warning("No <EOR> record terminators found in %s — file may be non-standard ADIF", adif_file)
    log.verbose("Parsed %d QSO(s) from %s (%d <EOR> tags)", len(records), adif_file, eor_count)

    # Apply filters
    if tail_days is not None:
        cutoff = (date.today() - timedelta(days=tail_days)).strftime("%Y%m%d")
        before = len(records)
        filtered, no_date = [], 0
        for r in records:
            d = _adif_qso_date(r)
            if not d:
                no_date += 1
                filtered.append(r)  # keep records with no parseable QSO_DATE
            elif d >= cutoff:
                filtered.append(r)
        if no_date:
            log.warning("%d QSO(s) had no parseable QSO_DATE and were kept without date filtering", no_date)
        records = filtered
        log.verbose("--tail-days %d: kept %d of %d QSO(s) on or after %s",
                    tail_days, len(records), before, cutoff)

    if tail is not None:
        before = len(records)
        records = records[-tail:]
        log.verbose("--tail %d: kept last %d of %d QSO(s)", tail, len(records), before)

    if not records:
        log.error("No QSOs to upload after filtering.")
        sys.exit(1)

    n = len(records)

    if dry_run:
        log.info("[dry-run] Would upload %d QSO(s) in %d INSERT call(s) to %s", n, n, QRZ_API_URL)
        for i, record in enumerate(records):
            adif = _build_adif(header, record)
            log.verbose("[dry-run] QSO %d/%d: %d bytes", i + 1, n, len(adif))
            log.trace("[dry-run] QSO %d/%d content:\n%s", i + 1, n, adif)
        return

    uploaded = 0
    for i, record in enumerate(records):
        adif = _build_adif(header, record)
        log.info("Uploading QSO %d/%d...", i + 1, n)
        log.verbose("QSO %d/%d: %d bytes", i + 1, n, len(adif))
        log.trace("QSO %d/%d content:\n%s", i + 1, n, adif)

        body = qrz_post({"KEY": api_key, "ACTION": "INSERT", "ADIF": adif}, log)
        log.debug("QSO %d/%d response: %s", i + 1, n, body[:300])
        log.trace("QSO %d/%d full response: %s", i + 1, n, body)

        result = parse_response(body)
        check_result(result, log)

        if result.get("RESULT") == "OK":
            log.verbose("QSO %d/%d accepted (COUNT=%s)", i + 1, n, result.get("COUNT", "?"))
            try:
                uploaded += int(result.get("COUNT", "0") or "0")
            except (ValueError, TypeError):
                pass
        else:
            log.error("Unexpected response for QSO %d/%d: %s", i + 1, n, body)
            sys.exit(1)

    log.info("Success: %d of %d QSO(s) uploaded.", uploaded or n, n)


FETCH_PAGE_SIZE = 250


def _strip_adif_header(adif: str) -> str:
    """Remove the ADIF header (everything up to and including <EOH>) if present."""
    idx = adif.upper().find("<EOH>")
    if idx == -1:
        return adif
    return adif[idx + 5:].lstrip()


def do_download(api_key: str, output_file: str, dry_run: bool, log: AppLogger) -> None:
    if dry_run:
        log.info("[dry-run] Would fetch full log (paginated, %d/page) from %s and save to %s",
                 FETCH_PAGE_SIZE, QRZ_API_URL, output_file)
        return

    chunks: list[str] = []
    after_logid = 0
    total = 0
    page = 0

    while True:
        option = f"MAX:{FETCH_PAGE_SIZE},AFTERLOGID:{after_logid}"
        page += 1

        log.info("Fetching page %d (after logid %d)...", page, after_logid)
        log.verbose("Page %d: FETCH OPTION=%s", page, option)

        body = qrz_post({"KEY": api_key, "ACTION": "FETCH", "OPTION": option}, log)
        log.debug("Page %d raw response (%d bytes): %s", page, len(body), body[:300].replace("\n", " "))
        log.trace("Page %d full response: %s", page, body)

        result = parse_response(body)
        check_result(result, log)

        if result.get("RESULT") != "OK":
            log.error("Unexpected response: %s", body)
            sys.exit(1)

        adif_chunk = result.get("ADIF", "").strip()
        try:
            count = int(result.get("COUNT", "0") or "0")
        except ValueError:
            count = 0

        log.verbose("Page %d: RESULT=%s COUNT=%d ADIF bytes=%d",
                    page, result.get("RESULT"), count, len(adif_chunk))

        if not adif_chunk or count == 0:
            log.verbose("No more records — stopping after %d page(s)", page)
            break

        # Only the first page keeps its ADIF header; subsequent pages drop it
        if chunks:
            adif_chunk = _strip_adif_header(adif_chunk)

        chunks.append(adif_chunk)
        total += count

        if count < FETCH_PAGE_SIZE:
            log.verbose("Page %d returned %d < %d — last page", page, count, FETCH_PAGE_SIZE)
            break

        # Advance the cursor to the highest app_qrzlog_logid seen in this page
        logids = [int(m) for m in re.findall(r"<app_qrzlog_logid:\d+>(\d+)", adif_chunk, re.IGNORECASE)]
        if not logids:
            log.warning("No app_qrzlog_logid fields in ADIF; cannot paginate further.")
            break
        after_logid = max(logids)
        log.verbose("Page %d: logids %d–%d, total so far %d, advancing cursor to %d",
                    page, min(logids), max(logids), total, after_logid)

    if not chunks:
        log.error("No QSOs found in log.")
        sys.exit(1)

    with open(output_file, "w", encoding="utf-8") as f:
        f.write("\n".join(chunks))
    log.info("Downloaded %d QSO(s) to %s", total, output_file)
    log.verbose("Wrote %d bytes across %d page(s)", sum(len(c) for c in chunks), page)


def _save_config_value(config_path: str, section: str, key: str, value: str) -> None:
    """Write a single key=value into a config section, creating file/section as needed."""
    cfg = configparser.ConfigParser()
    cfg.read(config_path)
    if not cfg.has_section(section):
        cfg.add_section(section)
    cfg.set(section, key, value)
    os.makedirs(os.path.dirname(config_path), exist_ok=True)
    with open(config_path, "w") as f:
        cfg.write(f)
    os.chmod(config_path, 0o600)


def main():
    # Load default config and detect log file before building the parser so the
    # status can appear in --help output.
    _pre_cfg = load_config(DEFAULT_CONFIG)
    _default_log = find_default_log_file(_pre_cfg)
    if _default_log:
        _log_hint = f"Default ADIF log: {_default_log} [found]"
    else:
        _log_hint = (f"Default ADIF log: not found"
                     f" (checked {', '.join(WSJT_X_LOG_CANDIDATES)})")

    parser = argparse.ArgumentParser(
        prog="qrzlog",
        description="Upload or download ADIF logs via the QRZ Logbook API.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            f"{_log_hint}\n\n"
            "API key: QRZ.com -> Logbook -> Settings -> API Key\n\n"
            "Config file format (~/.config/qrzlog/qrzlog.ini):\n"
            "  [qrzlog]\n"
            "  api_key  = YOUR_KEY_HERE\n"
            "  log_file = /path/to/wsjtx_log.adi\n\n"
            "  [logging]\n"
            "  level   = verbose    # trace | debug | verbose | info\n"
            "  logfile = /path/to/qrzlog.log\n"
            "  syslog  = false\n\n"
            "Examples:\n"
            "  qrzlog --save-key ABC123XYZ\n"
            "  qrzlog --save-log-file ~/.local/share/WSJT-X/wsjtx_log.adi\n"
            "  qrzlog --upload                    # uses configured/detected log file\n"
            "  qrzlog --upload contacts.adif\n"
            "  qrzlog --upload --tail 50\n"
            "  qrzlog --upload --tail-days 7\n"
            "  qrzlog --upload --dry-run --trace\n"
            "  qrzlog --download mylog.adif\n"
            "  qrzlog --download mylog.adif --verbose\n"
            "  qrzlog --download mylog.adif --debug --logfile qrzlog.log\n"
            "  qrzlog --download mylog.adif --dry-run"
        ),
    )

    mode = parser.add_mutually_exclusive_group(required=True)
    mode.add_argument(
        "--upload", metavar="FILE", nargs="?", const="",
        help="Upload ADIF to QRZ Logbook (FILE optional if default log configured or detected)",
    )
    mode.add_argument("--download",      metavar="FILE",    help="Download your complete QRZ log to FILE")
    mode.add_argument("--save-key",      metavar="API_KEY", help="Save API key to config file and exit")
    mode.add_argument("--save-log-file", metavar="FILE",    help="Save default ADIF log path to config and exit")

    parser.add_argument("--key",    metavar="API_KEY", help="QRZ API key (overrides config and QRZ_API_KEY env var)")
    parser.add_argument("--config", metavar="FILE", default=DEFAULT_CONFIG,
                        help=f"Config file path (default: {DEFAULT_CONFIG})")
    parser.add_argument("--dry-run", action="store_true", help="Show what would happen without making any requests")

    verbosity = parser.add_mutually_exclusive_group()
    verbosity.add_argument("--verbose", action="store_true", help="Show request details and pagination info")
    verbosity.add_argument("--debug",   action="store_true", help="Show raw API responses (implies --verbose)")
    verbosity.add_argument("--trace",   action="store_true", help="Show full untruncated responses (implies --debug)")

    parser.add_argument("--logfile", metavar="FILE",  help="Also write log output to FILE")
    parser.add_argument("--syslog",  action="store_true", help="Also send log output to syslog")

    tail_group = parser.add_mutually_exclusive_group()
    tail_group.add_argument("--tail",      metavar="N", type=int, help="Upload only the last N QSOs")
    tail_group.add_argument("--tail-days", metavar="N", type=int, help="Upload only QSOs from the last N days")

    args = parser.parse_args()

    # Validate upload-only flags
    if (args.tail is not None or args.tail_days is not None) and args.upload is None:
        used = ["--tail" if args.tail is not None else "--tail-days"]
        parser.error(f"{', '.join(used)} can only be used with --upload")

    # Load actual config (may differ from DEFAULT_CONFIG if --config was passed)
    cfg = load_config(args.config)
    log = AppLogger.from_args(args, "qrzlog", cfg=cfg)

    if args.save_key:
        _save_config_value(args.config, "qrzlog", "api_key", args.save_key)
        os.chmod(args.config, 0o600)
        print(f"API key saved to {args.config}")
        return

    if args.save_log_file:
        _save_config_value(args.config, "qrzlog", "log_file", args.save_log_file)
        print(f"Default log file saved to {args.config}")
        return

    api_key = resolve_api_key(args, cfg)

    if not api_key and not args.dry_run:
        parser.error(
            "No API key found. Use --key, set QRZ_API_KEY, or run:\n"
            f"  qrzlog --save-key YOUR_KEY  (saves to {args.config})"
        )

    if args.upload is not None:
        # Resolve the actual file path: explicit arg > config/detected default
        adif_file = args.upload or find_default_log_file(cfg)
        if not adif_file:
            parser.error(
                "--upload: no FILE given and no default log file found.\n"
                f"  Run: qrzlog --save-log-file /path/to/wsjtx_log.adi"
            )
        log.verbose("Using ADIF log file: %s", adif_file)
        do_upload(api_key or "", adif_file, args.dry_run, log,
                  tail=args.tail, tail_days=args.tail_days)
    elif args.download:
        do_download(api_key or "", args.download, args.dry_run, log)


if __name__ == "__main__":
    main()
